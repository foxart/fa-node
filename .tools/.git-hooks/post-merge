#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PARENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$PARENT_DIR/config.sh"
source "$PARENT_DIR/logger.sh"

HOOKS_NAME="$(loggerFormat "[HOOKS]")"

run() {
  if [[ "${HOOKS_DRY_RUN:-false}" == "true" ]]; then
    loggerDebug "$HOOKS_NAME run: $(loggerFormat "$1") ${*:2} dry-run"
    return 0
  fi
  loggerLog "$HOOKS_NAME run: $(loggerFormat "$1") ${*:2} started"
  "$@"
}

skip_if_requested() {
  if [[ "${SKIP_HOOKS:-}" == "true" ]]; then
    loggerInfo "$HOOKS_NAME check: $(loggerFormat "SKIP_HOOKS=true") skipped"
    exit 0
  fi
}

check_hooks_changed() {
  git rev-parse --verify ORIG_HEAD >/dev/null 2>&1 || return 1
  if git diff --quiet ORIG_HEAD HEAD -- .tools/.git-hooks; then
    return 1
  fi
  return 0
}

cleanup_cache() {
  if [[ "${GIT_PRUNE_IGNORED_FROM_INDEX:-false}" != "true" ]]; then
    return
  fi
  loggerInfo "$HOOKS_NAME cleanup: ignored cache started"
  local tmp
  tmp="$(mktemp)"
  git ls-files --ignored --exclude-standard --cached -z >"$tmp"
  while IFS= read -r -d '' f; do
    [[ -z "$f" ]] && continue
    git update-index --force-remove -- "$f"
  done <"$tmp"
  rm -f "$tmp"
}

main() {
  skip_if_requested
  if check_hooks_changed; then
    loggerInfo "$HOOKS_NAME sync: hooks changed"
    if run "$SCRIPT_DIR/.git-hooks.sh"; then
      loggerLog "$HOOKS_NAME sync: hooks updated"
    else
      loggerError "$HOOKS_NAME sync: hooks failed"
      return 1
    fi
  else
    loggerInfo "$HOOKS_NAME sync: hooks skipped"
  fi
  cleanup_cache
}

main "$@"
