#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/logger.sh"

NAME="$(loggerFormat "[PRE-PUSH]")"

skip_if_requested() {
  if [[ "${GIT_HOOKS_SKIP:-}" == "true" ]]; then
    loggerWarn "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
    exit 0
  fi
}

skip_if_nothing_to_push() {
  local line
  while IFS= read -r line; do
    [[ -n "$line" ]] && return
  done
#  loggerInfo "$NAME push: skip"
  loggerInfo "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
  exit 0
}

npm_run_test() {
  loggerInfo "$NAME test: started"
  if npm run test --silent; then
    loggerLog "$NAME test: passed"
  else
    loggerError "$NAME test: failed"
    exit 1
  fi
}

npm_run_build() {
  loggerInfo "$NAME build: started"
  if npm run build >/dev/null 2>&1; then
    loggerLog "$NAME build: passed"
  else
    loggerError "$NAME build: failed"
    exit 1
  fi
}

main() {
  skip_if_requested
  skip_if_nothing_to_push
  npm_run_test
  npm_run_build
}

main "$@"
