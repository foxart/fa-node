#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/logger.sh"
source "$SCRIPT_DIR/config.sh"

NAME="$(loggerFormat "[HOOKS]")"

skip_if_requested() {
  if [[ "${GIT_HOOKS_SKIP:-}" == "true" ]]; then
    loggerWarn "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
    exit 0
  fi
}

extract_ticket() {
  local branch="$1"
  if [[ "$branch" =~ $JIRA_REGEX ]]; then
    printf '%s' "${BASH_REMATCH[0]}"
  fi
}

append_ticket() {
  local file="$1"
  local branch
  branch="$(git rev-parse --abbrev-ref HEAD)"
  local ticket
  ticket="$(extract_ticket "$branch")"
  [[ -z "$ticket" ]] && return 0
  grep -qF -- "$ticket" "$file" && return 0
  printf '\nRefs %s/browse/%s\n' "$JIRA_URL" "$ticket" >>"$file"
  loggerLog "$NAME reference: $(loggerFormat "$ticket") added"
}

main() {
  skip_if_requested
  local file="${1:-}"
  if [[ -z "$file" ]]; then
    loggerError "$NAME commit message: file missing"
    exit 1
  fi
  append_ticket "$file"
}

main "$@"
