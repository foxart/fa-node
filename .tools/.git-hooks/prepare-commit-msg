#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/logger.sh"

NAME="$(loggerFormat "[PREPARE-COMMIT-MSG]")"

skip_if_requested() {
  if [[ "${GIT_HOOKS_SKIP:-}" == "true" ]]; then
    loggerWarn "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
    exit 0
  fi
}

main() {
  skip_if_requested
  local file="${1:-}"
  if [[ -z "$file" ]]; then
    loggerError "$NAME message: missing"
    exit 1
  fi
  local branch
  branch="$(git rev-parse --abbrev-ref HEAD)"
  local ticket=""
  if [[ "$branch" =~ $JIRA_REGEX ]]; then
    ticket="${BASH_REMATCH[0]}"
  fi
  [[ -z "$ticket" ]] && return 0
  grep -qF -- "$ticket" "$file" && return 0
  printf '\nRefs %s/browse/%s\n' "$JIRA_URL" "$ticket" >>"$file"
}

main "$@"
