#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/logger.sh"

NAME="$(loggerFormat "[PRE-COMMIT]")"

readonly STAGED_LINT_DIFF_FILTER="ACM"
readonly -a STAGED_LINT_FILE_PATTERNS=("*.ts" "*.js")

skip_if_requested() {
  if [[ "${GIT_HOOKS_SKIP:-}" == "true" ]]; then
    loggerWarn "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
    exit 0
  fi
}

get_staged_lint_files() {
  git diff --cached --name-only --diff-filter="$STAGED_LINT_DIFF_FILTER" -- "${STAGED_LINT_FILE_PATTERNS[@]}"
}

restage_staged_lint_files() {
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    git diff --quiet -- "$f" && continue
    git add -- "$f"
  done <<<"$1"
}

lint_staged_lint_files() {
  local input="$1"
  local files=()
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    files+=("$f")
  done <<<"$input"
  [[ "${#files[@]}" -eq 0 ]] && return 0
  loggerInfo "$NAME lint: started $(loggerFormat "${#files[@]}") files"
  if npm run lint --silent -- "${files[@]}"; then
    loggerLog "$NAME lint: passed $(loggerFormat "${#files[@]}") files"
  else
    loggerError "$NAME lint: failed $(loggerFormat "${#files[@]}") files"
    exit 1
  fi
}

main() {
  skip_if_requested
  local staged
  staged="$(get_staged_lint_files)"
  lint_staged_lint_files "$staged"
  restage_staged_lint_files "$staged"
}

main "$@"
