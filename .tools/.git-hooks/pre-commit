#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=.tools/config.sh
source "$SCRIPT_DIR/config.sh"
# shellcheck source=.tools/logger.sh
source "$SCRIPT_DIR/logger.sh"

HOOKS_NAME="$(loggerFormat "[PRE-COMMIT]")"

skip_if_requested() {
  if [[ "${GIT_SKIP_HOOK:-}" == "true" ]]; then
    loggerWarn "$HOOKS_NAME skip: $(loggerFormat "GIT_SKIP_HOOK=$GIT_SKIP_HOOK")"
    exit 0
  fi
}

restage_files() {
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ "$f" =~ \.(ts|js)$ ]] || continue
    git diff --quiet -- "$f" && continue
    git add -- "$f"
  done <<<"$1"
}

npm_run_lint() {
  local input="$1"
  shift
  local files=()
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ "$f" =~ \.(ts|js)$ ]] || continue
    files+=("$f")
  done <<<"$input"
  [[ "${#files[@]}" -eq 0 ]] && return 0
  loggerInfo "$HOOKS_NAME lint: started $(loggerFormat "${#files[@]}") files"
  if npm run lint --silent -- "${files[@]}"; then
    loggerLog "$HOOKS_NAME lint: passed $(loggerFormat "${#files[@]}") files"
  else
    loggerError "$HOOKS_NAME lint: failed $(loggerFormat "${#files[@]}") files"
    exit 1
  fi
}

main() {
  skip_if_requested
  local staged
  staged="$(git diff --cached --name-only --diff-filter=ACM)"
  npm_run_lint "$staged"
  restage_files "$staged"
}

main "$@"
