#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/logger.sh"

NAME="$(loggerFormat "[PRE-COMMIT]")"

skip_if_requested() {
  if [[ "${GIT_HOOKS_SKIP:-}" == "true" ]]; then
    loggerWarn "$NAME skip: $(loggerFormat "$GIT_HOOKS_SKIP")"
    exit 0
  fi
}

restage_files() {
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ "$f" =~ \.(ts|js)$ ]] || continue
    git diff --quiet -- "$f" && continue
    git add -- "$f"
  done <<<"$1"
}

npm_run_lint() {
  local input="$1"
  shift
  local files=()
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ "$f" =~ \.(ts|js)$ ]] || continue
    files+=("$f")
  done <<<"$input"
  [[ "${#files[@]}" -eq 0 ]] && return 0
  loggerInfo "$NAME lint: started $(loggerFormat "${#files[@]}") files"
  if npm run lint --silent -- "${files[@]}"; then
    loggerLog "$NAME lint: passed $(loggerFormat "${#files[@]}") files"
  else
    loggerError "$NAME lint: failed $(loggerFormat "${#files[@]}") files"
    exit 1
  fi
}

main() {
  skip_if_requested
  local staged
  staged="$(git diff --cached --name-only --diff-filter=ACM)"
  npm_run_lint "$staged"
  restage_files "$staged"
}

main "$@"
