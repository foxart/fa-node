#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/logger.sh"
source "$SCRIPT_DIR/git-hooks-common.sh"

NAME="$(loggerFormat "[POST-MERGE]")"

cleanup_cache() {
  if [[ "${GIT_PRUNE_IGNORED_FROM_INDEX:-false}" != "true" ]]; then
    return
  fi
  local tmp
  tmp="$(mktemp)"
  git ls-files --ignored --exclude-standard --cached -z >"$tmp"
  while IFS= read -r -d '' f; do
    [[ -z "$f" ]] && continue
    loggerInfo "$NAME ignored: $(loggerFormat "$f") pruned"
    #    git update-index --force-remove -- "$f"
  done <"$tmp"
  rm -f "$tmp"
}

sync_hooks() {
  if ! git rev-parse --verify ORIG_HEAD >/dev/null 2>&1 ||
    git diff --quiet ORIG_HEAD HEAD -- .tools/git-hooks; then
    loggerInfo "$NAME hooks: skipped"
    return 0
  fi
  loggerInfo "$NAME hooks: changed"
  if "$SCRIPT_DIR/git-hooks.sh"; then
    loggerLog "$NAME hooks: updated"
  else
    loggerError "$NAME hooks: failed"
    exit 1
  fi
}

main() {
  skip_git_hook_if_requested "$NAME"
  sync_hooks
  cleanup_cache
}

main "$@"
