{
  "name": "fa-node",
  "version": "1.0.1",
  "description": "",
  "author": "Ivan Kosenko",
  "license": "MIT",
  "homepage": "https://github.com/foxart/fa-node",
  "private": false,
  "scripts": {
    "start": "nodemon -e ts --watch src --watch playground -x ts-node playground/index.ts",
    "start:nest": "nodemon -e ts --watch src --watch nest --ignore dist -x ts-node --swc -r tsconfig-paths/register -P tsconfig.nest.json nest/main.ts",
    "migrator": "nodemon -e ts --watch src --watch playground --ignore node_modules -x ts-node playground/index.ts new my-test",
    "migrator-help": "ts-node playground/index.ts new --help",
    "prebuild": "rimraf dist",
    "build:assets": "cp src/cli/migration-mongo.template.ts dist/cli/migration-mongo.template.ts",
    "build": "tsc -p tsconfig.build.json && npm run build:assets",
    "lint": "eslint -c .eslintrc.js \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:nest": "jest --config test/jest-e2e.json",
    "prepack": "npm run build",
    "publish:public": "npm publish --access=public",
    "publish:dry": "npm publish --dry-run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@types/mongodb": "^4.0.7",
    "@types/mongoose": "^5.11.97",
    "apollo-server-errors": "^3.3.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "graphql": "^16.9.0",
    "mongodb": "^6.16.0",
    "ms": "^2.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^10.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.2",
    "@types/graphql": "^14.5.0",
    "@types/jest": "^29.5.12",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "@swc/core": "^1.11.29",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.4",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prettier-plugin-multiline-arrays": "^3.0.4",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  }
}
